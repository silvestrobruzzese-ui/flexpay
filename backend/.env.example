# Database
DATABASE_URL="postgresql://user:password@localhost:5432/flexpay"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CHECKOUT_URL=http://localhost:5173

# ============================================
# PAYMENT PROVIDERS
# ============================================

# STRIPE (Required)
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# PAYPAL (Optional)
# Get keys at: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_MODE="sandbox"  # "sandbox" or "live"

# MOLLIE (Optional)
# Get keys at: https://my.mollie.com/dashboard/developers/api-keys
MOLLIE_API_KEY="test_..."  # or "live_..." for production

# ============================================
# PROVIDERS THAT REQUIRE CONTRACTS
# (Contact them for API access)
# ============================================

# KLARNA - https://www.klarna.com/international/business/
# SATISPAY - https://business.satispay.com/
# SCALAPAY - https://www.scalapay.com/it/business
